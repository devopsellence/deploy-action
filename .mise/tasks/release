#!/usr/bin/env ruby
# frozen_string_literal: true

require "pathname"

ROOT = Pathname(__dir__).join("..", "..").expand_path
CLI_VERSION_PATH = ROOT.join("CLI_VERSION")
ACTION_PATH = ROOT.join("action.yml")

def abort_with(message)
  warn message
  exit 1
end

force_existing_tag = ARGV.delete("--force-existing-tag")
unknown_options = ARGV.grep(/\A--/)
abort_with("unknown option(s): #{unknown_options.join(', ')}") unless unknown_options.empty?

release_version = ARGV[0].to_s.strip
abort_with("usage: mise run release -- [--force-existing-tag] v1.0.0 [cli-version]") if release_version.empty?
abort_with("release version must look like v1.0.0") unless release_version.match?(/\Av\d+\.\d+\.\d+\z/)

cli_version = ARGV[1].to_s.strip
cli_version = CLI_VERSION_PATH.read.strip if cli_version.empty?
abort_with("CLI version must look like v0.1.0") unless cli_version.match?(/\Av\d+\.\d+\.\d+\z/)

status = `git status --porcelain`
abort_with("working tree not clean; commit first") unless $?.success? && status.empty?

major_version = release_version.sub(/\A(v\d+)\..+\z/, '\1')

CLI_VERSION_PATH.write("#{cli_version}\n")

original_action = ACTION_PATH.read
updated_action = original_action.sub(
  %r{docker://ghcr\.io/devopsellence/deploy-action:[^\s]+},
  "docker://ghcr.io/devopsellence/deploy-action:#{release_version}"
)
abort_with("could not update action image tag in action.yml") if updated_action == original_action && !original_action.include?("docker://ghcr.io/devopsellence/deploy-action:#{release_version}")

ACTION_PATH.write(updated_action)

release_tag_exists = system("git", "rev-parse", "-q", "--verify", "refs/tags/#{release_version}", out: File::NULL, err: File::NULL)
abort_with("tag #{release_version} already exists; rerun with --force-existing-tag to retag it") if release_tag_exists && !force_existing_tag

release_tag_command = if force_existing_tag
  ["git", "tag", "-fa", release_version, "-m", "Release #{release_version}"]
else
  ["git", "tag", "-a", release_version, "-m", "Release #{release_version}"]
end

add_command = ["git", "add", "CLI_VERSION", "action.yml"]
puts "$ #{add_command.join(' ')}"
abort_with("command failed: #{add_command.join(' ')}") unless system(*add_command)

release_commit_command = ["git", "commit", "-m", "Release #{release_version}"]
release_commit_needed = !system("git", "diff", "--cached", "--quiet")

if release_commit_needed
  puts "$ #{release_commit_command.join(' ')}"
  abort_with("command failed: #{release_commit_command.join(' ')}") unless system(*release_commit_command)
else
  puts "$ #{release_commit_command.join(' ')}"
  puts "skipped; no staged release metadata changes"
end

[
  release_tag_command,
  ["git", "tag", "-fa", major_version, "-m", "Release #{release_version}"]
].each do |command|
  puts "$ #{command.join(' ')}"
  abort_with("command failed: #{command.join(' ')}") unless system(*command)
end

puts
puts "next:"
puts "git push origin master"
puts(force_existing_tag ? "git push --force origin #{release_version}" : "git push origin #{release_version}")
puts "git push --force origin #{major_version}"
puts
puts "prepared #{release_version} with CLI #{cli_version}"
